# metadata
DAGSTER_POSTGRES_USER=
DAGSTER_POSTGRES_PASSWORD=
DAGSTER_POSTGRES_DB=

# dbt database connection
DBT_POSTGRES_HOST=
DBT_POSTGRES_PORT=
DBT_POSTGRES_USER=
DBT_POSTGRES_PASSWORD=
DBT_POSTGRES_DBNAME=
DBT_POSTGRES_SCHEMA=

# dlt destination (native dlt env vars)
DESTINATION__POSTGRES__CREDENTIALS__DATABASE=
DESTINATION__POSTGRES__CREDENTIALS__USERNAME=
DESTINATION__POSTGRES__CREDENTIALS__PASSWORD=
DESTINATION__POSTGRES__CREDENTIALS__HOST=
DESTINATION__POSTGRES__CREDENTIALS__PORT=
DESTINATION__POSTGRES__CREDENTIALS__CONNECT_TIMEOUT=34

# dlt source config
SOURCES__HARAVAN__BASE_URL=https://apis.haravan.com/com/
SOURCES__HARAVAN__API_TOKEN=

# Frappe / ERPNext API
SOURCES__FRAPPE__BASE_URL=https://erp.jemmia.vn/
SOURCES__FRAPPE__API_KEY=
SOURCES__FRAPPE__API_SECRET=

# Nocodb
SOURCES__NOCODB__BASE_URL=https://workspace.jemmia.vn/api/v2
SOURCES__NOCODB__API_TOKEN=

# Pancake
SOURCES__PANCAKE__BASE_URL=https://pages.fm/api

# Lark (Bitable) — wiki tokens live in ingestion/lark/resources/tables.yml (per table)
SOURCES__LARK__BASE_URL=https://open.larksuite.com/open-apis
SOURCES__LARK__APP_ID=
SOURCES__LARK__APP_SECRET=

# Google Sheets (GCP service account)
SOURCES__GOOGLE_SHEETS__CREDENTIALS__PROJECT_ID=
SOURCES__GOOGLE_SHEETS__CREDENTIALS__CLIENT_EMAIL=
SOURCES__GOOGLE_SHEETS__CREDENTIALS__PRIVATE_KEY=

# Dagster AuthKit
DAGSTER_AUTH_BACKEND=sql
DAGSTER_AUTH_SECRET_KEY=
DAGSTER_AUTH_ADMIN_USERNAME=admin
DAGSTER_AUTH_ADMIN_PASSWORD=
DAGSTER_AUTH_ENV=production
DAGSTER_AUTH_COOKIE_SECURE=false
DAGSTER_AUTH_COOKIE_SAMESITE=lax
DAGSTER_AUTH_COOKIE_NAME=dagster_session
DAGSTER_AUTH_SESSION_MAX_AGE=86400
DAGSTER_AUTH_AUDIT_LOG=true

#Infisical
INFISICAL_HOST=
PUBLIC_INFISICAL_TOKEN=
INFISICAL_WORKSPACE_ID=
INFISICAL_ENVIRONMENT=
INFISICAL_SECRET_PATH=
